{
  "name": "@rolster/react-components",
  "version": "19.4.6",
  "type": "module",
  "description": "Package containing UI components for React Project.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.cjs",
        "import": "./dist/esm/index.js"
      },
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/**/*.{ts}\"",
    "prettier:css": "prettier --write dist/**/*.css --ignore-path .prettierignore",
    "clean": "rimraf ./dist",
    "dev": "vite",
    "build:css": "sass src/:dist/esm/ --style=compressed",
    "build": "npm run clean && tsc -p tsconfig.app.json && npm run build:css && npm run prettier:css && rollup -c rollup.config.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@rolster/commons": "^4.1.1",
    "@rolster/components": "^2.1.0",
    "@rolster/dates": "^4.1.0",
    "@rolster/forms": "^4.1.2",
    "@rolster/i18n": "^3.1.0",
    "@rolster/react-forms": "^19.4.3",
    "@rolster/react-lottie": "^19.3.0",
    "@rolster/strings": "^3.1.0",
    "@rolster/validators": "^3.1.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.21.0",
    "@rolster/rollup": "^2.0.0",
    "@rolster/styles-foundations": "^2.7.3",
    "@rolster/types": "^1.1.0",
    "@types/node-sass": "^4.11.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "match-sorter": "^6.3.1",
    "object-path": "^0.11.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-import-css": "^3.3.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-swc": "^0.2.1",
    "sass": "^1.89.0",
    "sort-by": "^0.0.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/react-components.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=14.13"
  }
}
